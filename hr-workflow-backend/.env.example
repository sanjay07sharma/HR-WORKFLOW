# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection (replace with your Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hr_workflow?retryWrites=true&w=majority

# CORS Origins (comma-separated, set to your deployed frontend URL)
CORS_ORIGINS=https://your-frontend-url.vercel.app
